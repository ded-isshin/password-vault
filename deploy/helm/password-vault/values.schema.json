{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        },
        "loadBalancerIP": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "metricsPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "http": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowAllIngress": {
              "type": "boolean"
            },
            "ingressIPBlocks": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "namespaceSelector": {
              "type": "object"
            },
            "podSelector": {
              "type": "object"
            }
          }
        },
        "database": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "podSelector": {
              "type": "object"
            },
            "podSelectorOverride": {
              "type": "object"
            }
          }
        },
        "dns": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "kubeDns": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "namespaceSelector": {
                  "type": "object"
                },
                "podSelector": {
                  "type": "object"
                }
              }
            },
            "nodeLocal": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "cidr": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "topologySpreadConstraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxSkew": {
          "type": "integer",
          "minimum": 1
        },
        "topologyKey": {
          "type": "string",
          "minLength": 1
        },
        "whenUnsatisfiable": {
          "type": "string",
          "enum": [
            "DoNotSchedule",
            "ScheduleAnyway"
          ]
        },
        "matchLabelKeys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nodeAffinityPolicy": {
          "type": "string",
          "enum": [
            "Honor",
            "Ignore"
          ]
        },
        "nodeTaintsPolicy": {
          "type": "string",
          "enum": [
            "Honor",
            "Ignore"
          ]
        }
      }
    },
    "syntheticCleanup": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cronJob": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "schedule": {
              "type": "string",
              "minLength": 1
            },
            "timeZone": {
              "type": "string",
              "minLength": 1
            },
            "suspend": {
              "type": "boolean"
            },
            "concurrencyPolicy": {
              "type": "string",
              "enum": [
                "Allow",
                "Forbid",
                "Replace"
              ]
            },
            "startingDeadlineSeconds": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "successfulJobsHistoryLimit": {
              "type": "integer",
              "minimum": 0
            },
            "failedJobsHistoryLimit": {
              "type": "integer",
              "minimum": 0
            },
            "backoffLimit": {
              "type": "integer",
              "minimum": 0
            },
            "activeDeadlineSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "ttlSecondsAfterFinished": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "confirm": {
              "type": "boolean"
            },
            "prefix": {
              "type": "string",
              "pattern": "^[a-z0-9.-]{1,32}$"
            },
            "domain": {
              "type": "string",
              "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*\\.invalid$",
              "maxLength": 80
            },
            "minAgeHours": {
              "type": "integer",
              "minimum": 1
            },
            "maxDelete": {
              "type": "integer",
              "minimum": 1
            },
            "annotations": {
              "type": "object"
            },
            "resources": {
              "type": "object"
            }
          }
        }
      }
    },
    "syntheticJourney": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cronJob": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "schedule": {
              "type": "string",
              "minLength": 1
            },
            "timeZone": {
              "type": "string",
              "minLength": 1
            },
            "suspend": {
              "type": "boolean"
            },
            "concurrencyPolicy": {
              "type": "string",
              "enum": [
                "Allow",
                "Forbid",
                "Replace"
              ]
            },
            "startingDeadlineSeconds": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "successfulJobsHistoryLimit": {
              "type": "integer",
              "minimum": 0
            },
            "failedJobsHistoryLimit": {
              "type": "integer",
              "minimum": 0
            },
            "backoffLimit": {
              "type": "integer",
              "minimum": 0
            },
            "activeDeadlineSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "ttlSecondsAfterFinished": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "annotations": {
              "type": "object"
            },
            "nodeImage": {
              "type": "string",
              "pattern": "^.+@sha256:[a-f0-9]{64}$"
            },
            "imagePullPolicy": {
              "type": "string",
              "enum": [
                "Always",
                "IfNotPresent",
                "Never"
              ]
            },
            "baseUrl": {
              "type": "string"
            },
            "allowNonLocalBaseUrl": {
              "type": "boolean"
            },
            "tlsInsecure": {
              "type": "boolean"
            },
            "checkMetrics": {
              "type": "boolean"
            },
            "timeoutMs": {
              "type": "integer",
              "minimum": 1000
            },
            "loginPrefix": {
              "type": "string",
              "pattern": "^[a-z0-9.-]{1,32}$"
            },
            "emailDomain": {
              "type": "string",
              "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*\\.invalid$",
              "maxLength": 80
            },
            "resources": {
              "type": "object"
            }
          }
        },
        "networkPolicy": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowApiServiceEgress": {
              "type": "boolean"
            },
            "externalEgress": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "cidr",
                  "ports"
                ],
                "properties": {
                  "cidr": {
                    "type": "string",
                    "description": "Narrow IPv4 CIDR for explicit synthetic journey egress. Use /32 for a single edge host.",
                    "pattern": "^(?:(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.){3}(?:25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})/(?:1[6-9]|2[0-9]|3[0-2])$"
                  },
                  "ports": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
