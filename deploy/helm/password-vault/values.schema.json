{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "http": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowAllIngress": {
              "type": "boolean"
            }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "namespaceSelector": {
              "type": "object"
            },
            "podSelector": {
              "type": "object"
            }
          }
        },
        "database": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "podSelector": {
              "type": "object"
            }
          }
        },
        "dns": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "kubeDns": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "namespaceSelector": {
                  "type": "object"
                },
                "podSelector": {
                  "type": "object"
                }
              }
            },
            "nodeLocal": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "cidr": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "topologySpreadConstraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxSkew": {
          "type": "integer",
          "minimum": 1
        },
        "topologyKey": {
          "type": "string",
          "minLength": 1
        },
        "whenUnsatisfiable": {
          "type": "string",
          "enum": [
            "DoNotSchedule",
            "ScheduleAnyway"
          ]
        },
        "matchLabelKeys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nodeAffinityPolicy": {
          "type": "string",
          "enum": [
            "Honor",
            "Ignore"
          ]
        },
        "nodeTaintsPolicy": {
          "type": "string",
          "enum": [
            "Honor",
            "Ignore"
          ]
        }
      }
    }
  }
}
