{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "http": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowAllIngress": {
              "type": "boolean"
            }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "namespaceSelector": {
              "type": "object"
            },
            "podSelector": {
              "type": "object"
            }
          }
        },
        "database": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "podSelector": {
              "type": "object"
            },
            "podSelectorOverride": {
              "type": "object"
            }
          }
        },
        "dns": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "kubeDns": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "namespaceSelector": {
                  "type": "object"
                },
                "podSelector": {
                  "type": "object"
                }
              }
            },
            "nodeLocal": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "cidr": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "topologySpreadConstraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxSkew": {
          "type": "integer",
          "minimum": 1
        },
        "topologyKey": {
          "type": "string",
          "minLength": 1
        },
        "whenUnsatisfiable": {
          "type": "string",
          "enum": [
            "DoNotSchedule",
            "ScheduleAnyway"
          ]
        },
        "matchLabelKeys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nodeAffinityPolicy": {
          "type": "string",
          "enum": [
            "Honor",
            "Ignore"
          ]
        },
        "nodeTaintsPolicy": {
          "type": "string",
          "enum": [
            "Honor",
            "Ignore"
          ]
        }
      }
    },
    "syntheticCleanup": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cronJob": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "schedule": {
              "type": "string",
              "minLength": 1
            },
            "timeZone": {
              "type": "string",
              "minLength": 1
            },
            "suspend": {
              "type": "boolean"
            },
            "concurrencyPolicy": {
              "type": "string",
              "enum": [
                "Allow",
                "Forbid",
                "Replace"
              ]
            },
            "startingDeadlineSeconds": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "successfulJobsHistoryLimit": {
              "type": "integer",
              "minimum": 0
            },
            "failedJobsHistoryLimit": {
              "type": "integer",
              "minimum": 0
            },
            "backoffLimit": {
              "type": "integer",
              "minimum": 0
            },
            "activeDeadlineSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "ttlSecondsAfterFinished": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "confirm": {
              "type": "boolean"
            },
            "prefix": {
              "type": "string",
              "pattern": "^[a-z0-9.-]{1,32}$"
            },
            "domain": {
              "type": "string",
              "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*\\.invalid$",
              "maxLength": 80
            },
            "minAgeHours": {
              "type": "integer",
              "minimum": 1
            },
            "maxDelete": {
              "type": "integer",
              "minimum": 1
            },
            "annotations": {
              "type": "object"
            },
            "resources": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}
